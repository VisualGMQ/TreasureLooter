{
    "version": 4,
    "configurePresets": [
        {
            "name": "default",
            "binaryDir": "${sourceDir}/cmake-build",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX" : "install"
            }
        },
        {
            "name": "CI-Linux-Debug",
            "binaryDir": "${sourceDir}/cmake-build-debug",
            "generator": "Ninja"
        },
        {
            "name": "CI-Windows-Debug",
            "binaryDir": "${sourceDir}/cmake-build-debug",
            "cacheVariables": {
                "CMAKE_SYSTEM_VERSION" : "10.0.26100.0"
            }
        },
        {
            "name": "CI-Linux-Release",
            "binaryDir": "${sourceDir}/cmake-build-release",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX" : "install"
            }
        },
        {
            "name": "CI-Windows-Release",
            "binaryDir": "${sourceDir}/cmake-build-release",
            "cacheVariables": {
                "CMAKE_SYSTEM_VERSION" : "10.0.26100.0",
                "CMAKE_INSTALL_PREFIX" : "install"
            }
        }
    ]
}
