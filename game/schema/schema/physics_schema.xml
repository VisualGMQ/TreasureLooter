<schema>
    <include>common/math.hpp</include>
    <include>common/collision_group.hpp</include>
    <import>common</import>
    <import>collision_group_schema</import>

    <asset name="PhysicsShapeDefinition" extension=".physics_shape">
        <element name="is_rect" type="bool"/>
        <element name="rect" type="Rect"/>
        <element name="circle" type="Circle"/>
        <element name="collision_layer" type="CollisionGroup"/>
        <element name="collision_mask" type="CollisionGroup"/>
    </asset>

    <class name="CCTDefinition">
        <element name="skin" type="float" default="0.1"/>
        <element name="min_disp" type="float" default="0.001"/>
        <handle  name="physics_shape" type="PhysicsShapeDefinition"/>
    </class>

    <enum name="TriggerEventType">
        <item name="None"/>
        <item name="Coin"/>
        <item name="WeaponAttack"/>
        <item name="Digging"/>

        <item name="InteractableDetect"/>
    </enum>

    <class name="TriggerDefinition">
        <element name="event_type" type="TriggerEventType" default="TriggerEventType::None"/>
        <array name="physics_shapes" type="PhysicsShapeDefinitionHandle"/>
        <element name="trig_every_frame_when_touch" type="bool" default="false"/>
    </class>

    <class name="StaticCollisionDefinition">
        <array name="collisions" type="PhysicsShapeDefinitionHandle"/>
    </class>
</schema>
