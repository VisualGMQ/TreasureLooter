<schema>
    <include>entity.hpp</include>
    <import>prefab</import>
    <include>math.hpp</include>

    <enum name="EntityInstanceType">
        <item name="Instance"/>
        <item name="Prefab"/>
    </enum>

    <class name="EntityInstance">
        <option type="Transform" name="transform"/>
        <handle type="Prefab" name="prefab"/>
    </class>

    <asset name="SceneDefinition" extension=".scene">
        <element type="Path" name="script_path"/>
        <array type="EntityInstance" name="entities"/>
    </asset>
</schema>
