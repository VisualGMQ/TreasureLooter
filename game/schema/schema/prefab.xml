<schema>
    <include>common/transform.hpp</include>
    <import>draw_order</import>
    <import>sprite</import>
    <import>relationship</import>
    <import>anim</import>
    <import>anim_player</import>
    <import>physics_schema</import>
    <import>common</import>
    <import>tilemap_schema</import>
    <import>ui_config</import>
    <import>bind_point_schema</import>

    <class name="ReplicateInfo">
        <element name="raw_entity" type="Entity"/>
    </class>

    <asset name="Prefab" extension=".prefab">
        <option type="std::string" name="name"/>
        <option type="Transform" name="transform"/>
        <option type="DrawOrderDefinition" name="draw_order"/>
        <option type="SpriteDefinition" name="sprite"/>
        <array  type="PrefabHandle" name="children"/>
        <option type="MultiAnimationPlayerDefinition" name="animations"/>
        <option type="TilemapLayerDefinition" name="tilemap_layer"/>
        <option type="CCTDefinition" name="cct"/>
        <option type="TriggerDefinition" name="trigger"/>
        <option type="StaticCollisionDefinition" name="static_collision" />
        <array type="BindPointDefinition" name="bind_points"/>
        <element type="Path" name="client_script" />
        <element type="Path" name="server_script" />
        <handle type="UIWidgetDefinition" name="ui"/>
        <option type="ReplicateInfo" name="net_replicat_info"/>
    </asset>
</schema>
