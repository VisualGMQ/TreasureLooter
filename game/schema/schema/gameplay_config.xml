<schema>
    <include>common/image.hpp</include>
    <include>common/animation.hpp</include>
    <include>common/collision_group.hpp</include>
    <import>common</import>
    <import>physics_schema</import>
    <import>scene_definition</import>
    <import>tilemap_schema</import>
    <import>sprite</import>
    <import>anim_player</import>

    <enum name="TeamID">
        <item name="invalid" />
        <item name="neutral" />
        <item name="team1" />
        <item name="team2" />
    </enum>

    <enum name="DID">
        <item name="Invalid" value="0x0"/>
        <item name="CharacterDID1" value="0x10000"/>
        <item name="CharacterDID2"/>
        <item name="CharacterDID3"/>
        <item name="CharacterDID4"/>
        <item name="CharacterDID5"/>
        <item name="CharacterDID6"/>

        <item name="ItemDID1" value="0x20000"/>
        <item name="ItemDID2"/>
        <item name="ItemDID3"/>

        <item name="FXDID1" value="0x40000"/>
        <item name="FXDID2"/>
        <item name="FXDID3"/>
        <item name="FXDID4"/>
        <item name="FXDID5"/>

        <!--add whatever DID you need-->
    </enum>

    <enum name="ScriptType">
        <item name="Unknown" />
        <item name="Monster" />
        <item name="Item" />
    </enum>

    <enum name="ItemBehavior">
        <item name="None" value="0" />
        <item name="Diggable" value="0x01" />
        <item name="Choppable" value="0x02" />
        <item name="Eatable" value="0x04" />

        <item name="Pickupable" value="0x08" />
        <item name="Stackable" value="0x10" />
    </enum>

    <class name="Attackable">
        <handle name="collision" type="PhysicsShapeDefinition" />
        <handle name="attack_animation" type="Animation" />
        <element name="cooldown" type="float" default="3"/>
        <element name="damage" type="float" default="1"/>
    </class>

    <class name="SpawnObjectComponentDefinition">
        <element name="object_did" type="DID" />
        <element name="count" type="int" default="-1" />
        <array name="spawn_animations" type="AnimationHandle" />
    </class>

    <asset name="ItemDefinition" extension=".item">
        <flags name="behavior" type="ItemBehavior" />
        <element name="sprite" type="SpriteDefinition" />
        <handle name="collision" type="PhysicsShapeDefinition"/>
        <option name="attackable" type="Attackable" />
        <option name="spawn_object" type="SpawnObjectComponentDefinition" />
    </asset>

    <asset name="FXDefinition" extension=".fx">
        <element name="sprite" type="SpriteDefinition" />
        <element name="animation" type="AnimationPlayerDefinition" />
    </asset>

    <class name="MoveComponentDefinition">
        <element name="speed" type="float" default="100" />

        <handle name="move_left_animation" type="Animation" />
        <handle name="move_right_animation" type="Animation" />
        <handle name="move_up_animation" type="Animation" />
        <handle name="move_down_animation" type="Animation" />
    </class>

    <class name="HpComponentDefinition">
        <element name="hp" type="uint32_t" default="1" />

        <handle name="hurt_animation" type="Animation" />
        <handle name="dead_animation" type="Animation" />
        <element name="invincible_time" type="TimeType" default="1" />
    </class>

    <class name="InteractComponentDefinition">
        <element name="detect_range" type="float" default="50" />
        <element name="can_interact_range" type="float" default="30" />
        <element name="collision_mask" type="CollisionGroup" />
    </class>

    <asset name="CharacterDefinition" extension=".character_def">
        <handle name="sprite_sheet" type="Image" />
        <handle name="faceset" type="Image" />

        <element name="cct" type="CCTDefinition" />

        <element name="move" type="MoveComponentDefinition" />
        <element name="hp" type="HpComponentDefinition" />
        <option name="interact" type="InteractComponentDefinition" />

        <element name="init_weapon" type="DID" default="DID::Invalid" />
        <!--<handle name="pickaxe" type="WeaponDefinition" />-->
    </asset>

    <class name="PlayerRelatedDefinition">
        <element name="hint_fx_did" type="DID" default="DID::Invalid" />
    </class>

    <class name="MapLayerDefinition">
        <element name="name" type="std::string" />
        <element name="draw_order" type="DrawOrderDefinition" />
    </class>

    <class name="MapDefinition">
        <handle name="map" type="Tilemap" />
        <array name="layers" type="MapLayerDefinition" />
    </class>

    <class name="ObjectSpawnDefinition">
        <element name="did" type="DID" />
        <!--for object controller(player, AI)-->
        <element name="client_script" type="Path" />
        <element name="server_script" type="Path" />
        <element name="spawn_point_name" type="std::string" />
        <element name="spawn_on_layer" type="std::string" />
        <option name="team_id" type="TeamID" />
    </class>

    <asset name="LevelDefinition" extension=".level">
        <element name="map_definition" type="MapDefinition" />
        <element name="land" type="std::string" />
        <element name="player_related_definition" type="PlayerRelatedDefinition" />
        <array name="spawn_objects" type="ObjectSpawnDefinition"/>
    </asset>

    <asset name="ObjectDefinitionTable" extension=".object_definition_table">
        <unordered_map name="objects" key="DID" value="Path"/>
    </asset>
</schema>
