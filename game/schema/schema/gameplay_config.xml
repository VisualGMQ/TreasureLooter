<schema>
    <include>common/image.hpp</include>
    <include>common/animation.hpp</include>
    <include>common/math.hpp</include>
    <import>common</import>
    <import>physics_schema</import>
    <import>scene_definition</import>
    <import>tilemap_schema</import>
    <import>sprite</import>

    <enum name="TeamID">
        <item name="invalid" />
        <item name="neutral" />
        <item name="team1" />
        <item name="team2" />
    </enum>

    <enum name="WeaponType">
        <item name="Sweep" />
        <item name="Stab" />
    </enum>

    <asset name="MapDefinition" extension=".map">
        <element name="size" type="Vec2" default="{30, 100}"/>
        <element name="time" type="float" default="60" />
    </asset>
</schema>
