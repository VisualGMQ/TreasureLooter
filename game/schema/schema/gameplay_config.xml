<schema>
    <include>image.hpp</include>
    <include>animation.hpp</include>
    <import>common</import>
    <import>physics_schema</import>
    <import>scene_definition</import>
    <import>tilemap_schema</import>

    <enum name="TeamID">
        <item name="invalid" />
        <item name="neutral" />
        <item name="team1" />
        <item name="team2" />
    </enum>

    <enum name="ScriptType">
        <item name="Unknown" />
        <item name="Monster" />
        <item name="Item" />
    </enum>

    <enum name="WeaponType">
        <item name="Sweep" />
        <item name="Stab" />
    </enum>

    <asset name="WeaponDefinition" extension=".weapon_def">
        <element name="type" type="WeaponType" />
        <handle name="sprite" type="Image" />
        <element name="cooldown" type="float" default="1" />
        <element name="attack_speed" type="float" default="1" />
        <element name="damage" type="uint32_t" default="1" />

        <handle name="attack_animation" type="Animation" />
        <element name="hit_shapes" type="TriggerDefinition" />
        <array name="bind_points" type="BindPointDefinition" />
    </asset>

    <asset name="CharacterDefinition" extension=".character_def">
        <handle name="sprite_sheet" type="Image" />
        <handle name="faceset" type="Image" />
        <element name="speed" type="float" default="100" />
        <element name="hp" type="uint32_t" default="1" />

        <element name="cct" type="CCTDefinition" />

        <handle name="move_left_animation" type="Animation" />
        <handle name="move_right_animation" type="Animation" />
        <handle name="move_up_animation" type="Animation" />
        <handle name="move_down_animation" type="Animation" />

        <element name="script" type="Path" />

        <handle name="weapon" type="WeaponDefinition" />

        <element name="interact_range" type="float" default="50" />
    </asset>

    <class name="PlayerRelatedDefinition">
        <handle name="interactable_hint_image" type="Image" />
        <handle name="interactable_hint_animation" type="Animation" />
    </class>

    <enum name="ItemBehavior">
        <item name="None" value="0" />
        <item name="Diggable" value="0x01" />
        <item name="Choppable" value="0x02" />
        <item name="Eatable" value="0x04" />

        <item name="Pickupable" value="0x08" />
        <item name="Stackable" value="0x10" />
    </enum>

    <enum name="ItemType">
        <item name="Unknown" />
        <item name="Mine" />
    </enum>

    <asset name="ItemDefinition" extension=".item">
        <element name="sprite" type="SpriteDefinition" />
        <handle name="collision" type="PhysicsShapeDefinition" />
        <flags name="behavior" type="ItemBehavior" />
        <element name="type" type="ItemType" default="ItemType::Unknown" />
    </asset>

    <class name="MapLayerDefinition">
        <element name="name" type="std::string" />
        <element name="draw_order" type="DrawOrderDefinition" />
    </class>

    <class name="MapDefinition">
        <handle name="map" type="Tilemap" />
        <array name="layers" type="MapLayerDefinition" />

        <element name="player_put_on_layer" type="std::string" />
        <element name="player_spawn_point" type="std::string" />
        <handle name="player_character" type="CharacterDefinition" />
        <element name="player_related_definition" type="PlayerRelatedDefinition" />
        <element name="player_team_id" type="TeamID" default="TeamID::neutral" />
    </class>

    <class name="ObjectSpawnDefinition">
        <element name="asset" type="Path" />
        <option name="team_id" type="TeamID" />
    </class>

    <asset name="LevelDefinition" extension=".level">
        <element name="map_definition" type="MapDefinition" />
        <!-- key is spawn point name in map, value is gameplay relate asset(Character, Prefab...) -->
        <unordered_map name="spawn_objects" key="std::string" value="ObjectSpawnDefinition" />
    </asset>
</schema>
