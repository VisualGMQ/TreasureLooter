<schema>
    <include>common/math.hpp</include>

    <class name="Rect">
        <element name="center" type="Vec2" />
        <element name="half_size" type="Vec2" />
    </class>

    <class name="Circle">
        <element name="center" type="Vec2" />
        <element name="radius" type="float" default="0" />
    </class>

    <class name="Polygon">
        <array name="points" type="Vec2" />
    </class>

    <class name="Image9Grid">
        <element name="left" type="float" default="0" />
        <element name="right" type="float" default="0" />
        <element name="top" type="float" default="0" />
        <element name="bottom" type="float" default="0" />
        <element name="scale" type="float" default="1.0f" />
    </class>

    <enum name="EntityType">
        <item name="Normal" />
        <item name="Player" />
    </enum>

    <enum name="FPSOption">
        <item name="FPS_15" />
        <item name="FPS_30" />
        <item name="FPS_60" />
        <item name="FPS_90" />
        <item name="FPS_120" />
        <item name="FPS_144" />
        <item name="NoLimit" />
    </enum>
</schema>
